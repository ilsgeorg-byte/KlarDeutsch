# KlarDeutsch Environment Configuration

# === PostgreSQL ===
# Формат: postgresql://[user]:[password]@[host]:[port]/[database]
# Пример для локального запуска:
POSTGRES_URL=postgresql://postgres:password@localhost:5432/klardeutsch

# === Redis (кэширование) ===
# Хост и порт Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Пароль (если требуется, для Redis Cloud или защищённых инсталляций)
# REDIS_PASSWORD=your_redis_password
# Номер базы данных (0 по умолчанию)
REDIS_DB=0
# Включить/выключить кэширование (true/false)
REDIS_ENABLED=true

# === Загрузки ===
# Директория для сохранения аудиозаписей
# По умолчанию: api/uploads
# ВАЖНО: используйте абсолютный или относительный путь
UPLOAD_DIR=./api/uploads

# === Flask ===
# Режим разработки (true/false)
FLASK_ENV=development
FLASK_DEBUG=true

# === JWT Secret ===
# Секретный ключ для JWT токенов (минимум 32 символа!)
# Сгенерировать можно так: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars!

# === Next.js ===
# URL API бэкенда для фронтенда (для production)
NEXT_PUBLIC_API_URL=https://api.klardeutsch.com
# URL сайта для metadataBase (Open Graph, Twitter Cards)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
